# CORO OCR Server - Environment Configuration
# Salin file ini ke CORO/.env dan isi API key Anda

# ── Groq API Key (WAJIB untuk performa cepat 2-4 detik) ──────
# Daftar gratis di: https://console.groq.com
# Model yang dipakai: meta-llama/llama-4-scout-17b-16e-instruct
GROQ_API_KEY=gsk_YourGroqApiKeyHere

# ── HuggingFace API Key (Fallback jika Groq tidak tersedia) ──
HF_API_KEY=hf_YourHuggingFaceApiKeyHere
